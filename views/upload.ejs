<%- include("partials/header") %>

<section class="panel">
  <div class="section-heading">
    <div>
      <h2>Upload PO, DO/GRN, and Supplier Invoice</h2>
      <p>Accepted file types: .xlsx, .xls, and .csv. The first worksheet and first data row will be extracted automatically.</p>
    </div>
  </div>

  <form action="/upload" method="POST" enctype="multipart/form-data">
    <div class="upload-grid two-column">
      <label class="upload-box">
        <span>Purchase Order Excel file</span>
        <small>Columns: Supplier Name, PO Number, Item Description, Quantity Ordered, Unit Price, Total Amount, Document Date.</small>
        <input type="file" name="poFile" accept=".xlsx,.xls,.csv" required>
      </label>

      <label class="upload-box">
        <span>DO / GRN Excel file</span>
        <small>Columns: Supplier Name, PO Number, DO/GRN Number, Item Description, Quantity Received, Document Date.</small>
        <input type="file" name="doGrnFile" accept=".xlsx,.xls,.csv" required>
      </label>

      <label class="upload-box">
        <span>Supplier Invoice Excel file</span>
        <small>Columns: Supplier Name, PO Number, Invoice Number, Item Description, Quantity Billed, Unit Price, Total Amount, Document Date.</small>
        <input type="file" name="invoiceFile" accept=".xlsx,.xls,.csv" required>
      </label>
    </div>

    <div class="form-actions">
      <button type="submit">Upload and Extract Data</button>
    </div>
  </form>
</section>

<section class="panel muted-panel">
  <h2>Excel Column Guide</h2>
  <p>Purchase Order: Supplier Name, PO Number, Item Description, Quantity Ordered, Unit Price, Total Amount, Document Date.</p>
  <p>DO/GRN: Supplier Name, PO Number, DO/GRN Number, Item Description, Quantity Received, Document Date.</p>
  <p>Supplier Invoice: Supplier Name, PO Number, Invoice Number, Item Description, Quantity Billed, Unit Price, Total Amount, Document Date.</p>
</section>

<%- include("partials/footer") %>
