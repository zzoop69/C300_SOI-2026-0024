<%- include("partials/header") %>

<section class="panel">
  <div class="section-heading">
    <div>
      <h2>Dynamic 3-Way Matching Results</h2>
      <p>PO, DO/GRN, and Supplier Invoice values are compared from uploaded Excel data and saved corrections.</p>
    </div>
  </div>

  <% if (records.length === 0) { %>
    <div class="empty-state">No matching results yet. Upload and review documents first.</div>
  <% } %>

  <% records.forEach((record) => { %>
    <article class="match-block">
      <div class="match-title">
        <div>
          <h3>Record #<%= record.id %></h3>
          <p><%= record.matching.message %></p>
        </div>
        <span class="status <%= record.matching.status.toLowerCase().replaceAll(' ', '-') %>"><%= record.matching.status %></span>
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Field</th>
              <th>Purchase Order</th>
              <th>DO/GRN</th>
              <th>Supplier Invoice</th>
              <th>Result</th>
            </tr>
          </thead>
          <tbody>
            <% record.matching.rows.forEach((row) => { %>
              <tr class="<%= row.result === 'Mismatch' ? 'highlight-row' : '' %>">
                <td><%= row.label %></td>
                <td><%= row.poValue %></td>
                <td><%= row.doGrnValue %></td>
                <td><%= row.invoiceValue %></td>
                <td><span class="status <%= row.result.toLowerCase() %>"><%= row.result %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (record.discrepancies.length > 0) { %>
        <h3 class="subheading">Discrepancies</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Mismatch Field</th>
                <th>PO Value</th>
                <th>DO/GRN Value</th>
                <th>Invoice Value</th>
                <th>Type</th>
                <th>Recommended Action</th>
              </tr>
            </thead>
            <tbody>
              <% record.discrepancies.forEach((discrepancy) => { %>
                <tr>
                  <td><%= discrepancy.field %></td>
                  <td><%= discrepancy.poValue %></td>
                  <td><%= discrepancy.doGrnValue %></td>
                  <td><%= discrepancy.invoiceValue %></td>
                  <td><%= discrepancy.type %></td>
                  <td><%= discrepancy.action %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </article>
  <% }) %>
</section>

<%- include("partials/footer") %>
