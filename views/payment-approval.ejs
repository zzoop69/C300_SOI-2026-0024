<%- include("partials/header") %>

<%
  const viewRecords = locals.records || [];
  const viewPaymentList = locals.paymentList || [];
  const viewStatusGroups = locals.statusGroups || {};
  const viewCurrentFilter = locals.currentFilter || "all";
  const viewSuccess = Boolean(locals.success);
  const actionNeededRecords = viewStatusGroups.actionNeeded || [
    ...(viewStatusGroups.pending || []),
    ...(viewStatusGroups.held || []),
  ];
  const approvedProcessingRecords = viewStatusGroups.approvedProcessing || [
    ...(viewStatusGroups.approved || []),
    ...(viewStatusGroups.processing || []),
  ];
  const statusClass = (value) => String(value || "neutral").toLowerCase().replaceAll(" ", "-").replaceAll("/", "-");
  const filters = [
    { key: "all", label: "All" },
    { key: "pending", label: "Pending" },
    { key: "approved", label: "Approved" },
    { key: "processing", label: "Processing" },
    { key: "rejected", label: "Rejected" },
    { key: "paid", label: "Paid" },
  ];
  const sections = [
    {
      title: "Pending / Action Needed",
      description: "Invoices still awaiting approval or review.",
      records: actionNeededRecords,
      filters: ["all", "pending"],
    },
    {
      title: "Approved / Processing",
      description: "Invoices approved for payment or currently being processed.",
      records: approvedProcessingRecords.filter((record) =>
        viewCurrentFilter === "processing" ? record.paymentStatus === "Payment Processing" : true
      ).filter((record) =>
        viewCurrentFilter === "approved" ? record.paymentStatus === "Approved for Payment" : true
      ),
      filters: ["all", "approved", "processing"],
    },
    {
      title: "Rejected",
      description: "Invoices rejected by staff.",
      records: viewStatusGroups.rejected || [],
      filters: ["all", "rejected"],
    },
    {
      title: "Paid",
      description: "Invoices marked as paid with demo transaction details.",
      records: viewStatusGroups.paid || [],
      filters: ["all", "paid"],
    },
  ].filter((section) => section.filters.includes(viewCurrentFilter));
%>

<section class="panel">
  <div class="section-heading">
    <div>
      <h2>Supplier Payment List</h2>
      <p>Action-needed invoices exclude Paid and Rejected records.</p>
    </div>
  </div>

  <% if (viewSuccess) { %>
    <div class="notice success-notice">Payment status updated successfully.</div>
  <% } %>

  <% if (viewPaymentList.length === 0) { %>
    <div class="empty-state">No records found.</div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Supplier</th>
            <th>Invoice</th>
            <th>PO Number</th>
            <th>Amount Payable</th>
            <th>Match Status</th>
            <th>Validation Status</th>
            <th>Approval Status</th>
            <th>Payment Status</th>
          </tr>
        </thead>
        <tbody>
          <% viewPaymentList.forEach((record) => { %>
            <tr>
              <td><%= record.invoice?.supplierName || record.purchaseOrder?.supplierName || "Missing" %></td>
              <td><%= record.invoice?.invoiceNumber || "Missing" %></td>
              <td><%= record.purchaseOrder?.poNumber || "Missing" %></td>
              <td>$<%= Number(record.amountPayable || 0).toFixed(2) %></td>
              <td><span class="status <%= statusClass(record.matching.status) %>"><%= record.matching.status %></span></td>
              <td><span class="status <%= statusClass(record.validation.status) %>"><%= record.validation.status %></span></td>
              <td><%= record.approvalStatus %></td>
              <td><span class="status <%= statusClass(record.paymentStatus) %>"><%= record.paymentStatus %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<section class="panel">
  <div class="section-heading">
    <div>
      <h2>Payment Approval Workflow</h2>
      <p>This is a demo approval and payment flow only. It does not connect to a real payment gateway.</p>
    </div>
  </div>

  <nav class="filter-bar" aria-label="Payment approval filters">
    <% filters.forEach((filter) => { %>
      <a class="<%= viewCurrentFilter === filter.key ? 'active' : '' %>" href="/payment-approval?filter=<%= filter.key %>"><%= filter.label %></a>
    <% }) %>
  </nav>

  <% if (viewRecords.length === 0) { %>
    <div class="empty-state">No records found.</div>
  <% } %>

  <% sections.forEach((section) => { %>
    <div class="approval-section">
      <div class="section-heading compact-heading">
        <div>
          <h3><%= section.title %></h3>
          <p><%= section.description %></p>
        </div>
      </div>

      <% if (section.records.length === 0) { %>
        <div class="empty-state">No records found.</div>
      <% } else { %>
        <div class="approval-grid">
          <% section.records.forEach((record) => { %>
            <article class="approval-card">
              <div class="card-heading">
                <h3><%= record.invoice?.supplierName || record.purchaseOrder?.supplierName || "Needs review" %></h3>
                <span class="status <%= statusClass(record.paymentStatus) %>"><%= record.paymentStatus %></span>
              </div>

              <dl class="details-list">
                <div><dt>Invoice Number</dt><dd><%= record.invoice?.invoiceNumber || "Missing" %></dd></div>
                <div><dt>PO Number</dt><dd><%= record.purchaseOrder?.poNumber || "Missing" %></dd></div>
                <div><dt>DO/GRN Number</dt><dd><%= record.deliveryOrder?.doGrnNumber || "Missing" %></dd></div>
                <div><dt>Amount Payable</dt><dd>$<%= Number(record.amountPayable || 0).toFixed(2) %></dd></div>
                <div><dt>Match Status</dt><dd><span class="status <%= statusClass(record.matching.status) %>"><%= record.matching.status %></span></dd></div>
                <div><dt>Validation Status</dt><dd><span class="status <%= statusClass(record.validation.status) %>"><%= record.validation.status %></span></dd></div>
                <div><dt>Discrepancies</dt><dd><%= record.unresolvedDiscrepancies.length %></dd></div>
              </dl>

              <% if (!record.canApprovePayment && record.paymentStatus !== "Paid" && record.paymentStatus !== "Rejected") { %>
                <div class="notice">Approve is disabled because Match Status must be Matched, Validation Status must be Valid, and Discrepancies must be 0.</div>
              <% } %>

              <% if (record.paymentStatus !== "Paid" && record.paymentStatus !== "Rejected") { %>
                <div class="approval-actions">
                  <form action="/payment-approval/<%= record.id %>/approve" method="POST">
                    <button type="submit" <%= record.canApprovePayment ? "" : "disabled" %>>Approve</button>
                  </form>
                  <form action="/payment-approval/<%= record.id %>/process" method="POST">
                    <button class="secondary-button" type="submit" <%= record.paymentStatus === "Approved for Payment" ? "" : "disabled" %>>Processing</button>
                  </form>
                  <form action="/payment-approval/<%= record.id %>/paid" method="POST">
                    <input type="hidden" name="paymentMethod" value="Demo Bank Transfer">
                    <button class="secondary-button" type="submit" <%= record.paymentStatus === "Approved for Payment" || record.paymentStatus === "Payment Processing" ? "" : "disabled" %>>Mark Paid</button>
                  </form>
                  <form action="/payment-approval/<%= record.id %>/reject" method="POST">
                    <button class="danger-button" type="submit">Reject</button>
                  </form>
                </div>
              <% } %>
            </article>
          <% }) %>
        </div>
      <% } %>
    </div>
  <% }) %>
</section>

<%- include("partials/footer") %>
