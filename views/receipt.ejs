<%- include("partials/header") %>

<section class="panel receipt-panel">
  <div class="section-heading">
    <div>
      <h2>Demo Payment Receipt</h2>
      <p>This receipt is generated by the demo workflow only.</p>
    </div>
    <a class="button" href="/reports">View Reports</a>
  </div>

  <dl class="details-list">
    <div><dt>Supplier</dt><dd><%= record.invoice?.supplierName || record.purchaseOrder?.supplierName || "Missing" %></dd></div>
    <div><dt>Invoice Number</dt><dd><%= record.invoice?.invoiceNumber || "Missing" %></dd></div>
    <div><dt>PO Number</dt><dd><%= record.purchaseOrder?.poNumber || "Missing" %></dd></div>
    <div><dt>Amount Paid</dt><dd>$<%= Number(record.payment?.amountPaid || 0).toFixed(2) %></dd></div>
    <div><dt>Transaction ID</dt><dd><%= record.payment?.transactionId || "-" %></dd></div>
    <div><dt>Payment Method</dt><dd><%= record.payment?.method || "-" %></dd></div>
    <div><dt>Paid At</dt><dd><%= record.payment?.paidAt ? new Date(record.payment.paidAt).toLocaleString() : "-" %></dd></div>
  </dl>
</section>

<%- include("partials/footer") %>
