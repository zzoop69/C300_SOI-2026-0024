<%- include("partials/header") %>

<section class="panel">
  <div class="section-heading">
    <div>
      <h2>Extracted Data Records</h2>
      <p>Select a saved record to review or correct the extracted Excel fields.</p>
    </div>
    <a class="button" href="/upload">Upload New Files</a>
  </div>

  <% if (records.length === 0) { %>
    <div class="empty-state">No extracted records yet.</div>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Record</th>
            <th>Uploaded</th>
            <th>PO File</th>
            <th>DO/GRN File</th>
            <th>Invoice File</th>
            <th>Supplier</th>
            <th>Status</th>
            <th>Review</th>
          </tr>
        </thead>
        <tbody>
          <% records.forEach((record) => { %>
            <tr>
              <td>#<%= record.id %></td>
              <td><%= new Date(record.createdAt).toLocaleDateString() %></td>
              <td><%= record.purchaseOrderFile?.originalName || "Missing" %></td>
              <td><%= record.deliveryOrderFile?.originalName || "Missing" %></td>
              <td><%= record.invoiceFile?.originalName || "Missing" %></td>
              <td><%= record.invoice?.supplierName || record.purchaseOrder?.supplierName || "Needs Review" %></td>
              <td><span class="status <%= record.extractionStatus.toLowerCase().replaceAll(' ', '-') %>"><%= record.extractionStatus %></span></td>
              <td><a class="table-link" href="/extract/<%= record.id %>">Open review</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include("partials/footer") %>
